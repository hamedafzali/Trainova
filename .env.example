# Self-hosted backend (accounts + sync). Copy to .env on the server.
# Postgres is internal-only; nothing here is exposed publicly.

# Strong random values in production:
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string

# "1" shows the login UI (server has a database). Baked at build time.
NEXT_PUBLIC_AUTH_ENABLED=1
