# Backend variables (accounts + sync).
#
# In AdvancedContainerManager: set these in the project's *Variables* — ACM
# detects POSTGRES_PASSWORD and JWT_SECRET as required (from docker-compose.yml)
# and injects them when it runs compose. No .env file needed there.
#
# This file is only for running compose manually (copy to .env). Postgres is
# internal-only; nothing here is exposed publicly.

POSTGRES_PASSWORD=change-me-to-a-strong-random-string
JWT_SECRET=change-me-to-a-long-random-string

# "1" shows the login UI (baked at build time). Has a default of 1; optional.
NEXT_PUBLIC_AUTH_ENABLED=1
